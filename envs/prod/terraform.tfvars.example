# ------------------------------------------------------------------------------
# Common
# ------------------------------------------------------------------------------

aws_region   = "ap-northeast-2"
project_name = "petcarelog"
environment  = "prod"

# ------------------------------------------------------------------------------
# GitHub / OIDC
# ------------------------------------------------------------------------------

github_owner  = "CLD-05"
github_repo   = "team5-app"
github_branch = "main"

# ------------------------------------------------------------------------------
# VPC / Network
# ------------------------------------------------------------------------------

vpc_cidr = "10.1.0.0/16"

public_subnet_cidrs = [
  "10.1.1.0/24",
  "10.1.2.0/24"
]

private_app_subnet_cidrs = [
  "10.1.11.0/24",
  "10.1.12.0/24"
]

private_db_subnet_cidrs = [
  "10.1.21.0/24",
  "10.1.22.0/24"
]

enable_nat_gateway = true

# prod는 NAT Gateway 2개
single_nat_gateway = false

# ------------------------------------------------------------------------------
# Bastion
# ------------------------------------------------------------------------------

# prod는 Bastion 생성하지 않음


# ------------------------------------------------------------------------------
# Ports
# ------------------------------------------------------------------------------

app_port = 8080
db_port  = 3306

# ------------------------------------------------------------------------------
# RDS
# ------------------------------------------------------------------------------

db_engine         = "mysql"
db_engine_version = "8.0"
db_instance_class = "db.t3.micro"

db_allocated_storage = 20
db_name              = "petcarelog_prod"
db_username          = "petcarelog"
db_password          = "CHANGE_ME_PROD_PASSWORD"

# prod는 강사님 요청대로 Multi-AZ
db_multi_az            = true
db_publicly_accessible = false

db_backup_retention_period = 7
db_deletion_protection     = true
db_skip_final_snapshot     = false

# ------------------------------------------------------------------------------
# EKS
# ------------------------------------------------------------------------------

eks_cluster_version         = "1.33"
eks_endpoint_public_access  = true
eks_endpoint_private_access = true

node_group_instance_types = [
  "t3.medium"
]

node_group_desired_size = 2
node_group_min_size     = 2
node_group_max_size     = 4
node_group_disk_size    = 20

# ------------------------------------------------------------------------------
# EKS Add-ons
# ------------------------------------------------------------------------------

eks_addons = [
  "vpc-cni",
  "coredns",
  "kube-proxy",
  "eks-pod-identity-agent"
]

# ------------------------------------------------------------------------------
# ElastiCache Redis
# ------------------------------------------------------------------------------

redis_node_type      = "cache.t3.micro"
redis_engine_version = "7.1"
redis_port           = 6379

redis_num_cache_clusters         = 2
redis_multi_az_enabled           = true
redis_automatic_failover_enabled = true

redis_at_rest_encryption_enabled = true
redis_transit_encryption_enabled = false