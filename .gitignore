# -------------------------------------------------------------------
# Terraform state files
# -------------------------------------------------------------------
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup
.terraform.lock.hcl

# -------------------------------------------------------------------
# Terraform working directory
# -------------------------------------------------------------------
.terraform/

# -------------------------------------------------------------------
# Terraform plan files
# -------------------------------------------------------------------
*.tfplan
*.plan
plan.out

# -------------------------------------------------------------------
# Terraform variable files that may contain secrets
# -------------------------------------------------------------------
*.tfvars
*.tfvars.json

# Example variable files are allowed
!*.tfvars.example
!terraform.tfvars.example

# -------------------------------------------------------------------
# Override files
# -------------------------------------------------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------------------------------------------------
# CLI configuration
# -------------------------------------------------------------------
.terraformrc
terraform.rc

# -------------------------------------------------------------------
# Crash logs
# -------------------------------------------------------------------
crash.log
crash.*.log

# -------------------------------------------------------------------
# Local environment files
# -------------------------------------------------------------------
.env
.env.*
*.env

# -------------------------------------------------------------------
# AWS credentials or local secrets
# -------------------------------------------------------------------
.aws/
credentials
config

# -------------------------------------------------------------------
# SSH keys / certificates
# -------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12

# -------------------------------------------------------------------
# OS / Editor files
# -------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo